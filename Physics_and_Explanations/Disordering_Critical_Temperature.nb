 RowBox[{
  RowBox[{"width", "=", 
   RowBox[{"height", " ", "=", " ", "30"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"configuration", " ", "=", 
   RowBox[{"randomConfiguration", "[", 
    RowBox[{
     RowBox[{"1", "/", "2"}], ",", 
     RowBox[{"{", 
      RowBox[{"30", ",", "30"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"configuration", ",", " ", "statistics"}], "}"}], " ", "=", 
    RowBox[{"latticeGasMetropolisSweep", "[", 
     RowBox[{"configuration", ",", 
      RowBox[{"10", "^", "6"}], ",", "\[IndentingNewLine]", 
