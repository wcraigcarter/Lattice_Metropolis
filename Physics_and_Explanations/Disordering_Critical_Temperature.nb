Cell["The average order parameter should be much less than 1.", "Text",
 CellChangeTimes->{{3.993728965658433*^9, 3.993728983999483*^9}, {
  3.993729451321974*^9, 
  3.993729456441901*^9}},ExpressionUUID->"cf36b0d8-7ccf-4048-a59d-\
3e17c61e1abf"],

Cell["\<\
To get a sense of how the averaged checkerboard parameter should behave for a \
typical random configuration:\
\>", "Text",
 CellChangeTimes->{{3.9937294598188066`*^9, 3.993729460454814*^9}, {
  3.9937295023426332`*^9, 3.9937295273214817`*^9}, {3.993729579421769*^9, 
  3.993729593340683*^9}},ExpressionUUID->"92bffcf1-122e-40af-855f-\
813beb6214ec"],

Cell[BoxData[
 RowBox[{
  RowBox[{"disorderedParameterSamples", " ", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"random", " ", "=", " ", 
         RowBox[{"randomConfiguration", "[", 
          RowBox[{
           RowBox[{"1", "/", "2"}], ",", 
           RowBox[{"{", 
            RowBox[{"30", ",", "30"}], "}"}]}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"orderParameters", " ", "=", " ", 
         RowBox[{"latticeGasOrderParameterMaps", "[", 
          RowBox[{"random", ",", "8"}], "]"}]}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        FractionBox["1", 
         RowBox[{"width", " ", "height"}]], 
        RowBox[{"Total", "[", 
         RowBox[{"Abs", "[", 
          RowBox[{"Flatten", "[", 
           RowBox[{"orderParameters", "[", "\"\<checkerboard\>\"", "]"}], 
           "]"}], "]"}], "]"}]}]}], "\[IndentingNewLine]", "]"}], ",", 
     "\[IndentingNewLine]", "1000"}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.993729033723995*^9, 3.993729151896839*^9}, {
  3.9937291836241217`*^9, 3.993729189689108*^9}, {3.993729376639715*^9, 
