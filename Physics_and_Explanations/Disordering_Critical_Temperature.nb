Cell["\<\
should produce a checkerboard signal that approaches 1 (there are some edges \
effects that prevent the value from being exactly 1).  We can measure that by \
computing the average square order parameter:\
\>", "Text",
 CellChangeTimes->{{3.9937281803915157`*^9, 3.9937282261003437`*^9}, {
  3.993728314008707*^9, 3.993728349132513*^9}, {3.99372870998064*^9, 
  3.9937287718993187`*^9}},ExpressionUUID->"c4045d3c-8911-4ec2-ac21-\
fa2f24ed725b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"orderParameters", "=", 
    RowBox[{"latticeGasOrderParameterMaps", "[", 
     RowBox[{"configuration", ",", "8"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 FractionBox[
  RowBox[{"Total", "[", 
   RowBox[{"Abs", "@", 
    RowBox[{"Flatten", "@", 
     RowBox[{"orderParameters", "[", "\"\<checkerboard\>\"", "]"}]}]}], "]"}], 
  RowBox[{"width", " ", "height", " "}]]}], "Input",
 CellChangeTimes->{{3.993728401188312*^9, 3.99372842011933*^9}, 
   3.993728505010458*^9, {3.993728632544929*^9, 3.993728636657422*^9}},
 CellLabel->
  "In[274]:=",ExpressionUUID->"615fed6d-b2a4-494c-adc5-33a55d2e3e33"],

Cell[BoxData["0.8088928294228991`"], "Output",
 CellChangeTimes->{{3.9937284139964323`*^9, 3.99372842087938*^9}, 
   3.993728472790093*^9, 3.9937286375217113`*^9, 3.993728684665895*^9},
 CellLabel->
  "Out[275]=",ExpressionUUID->"d444547b-4089-4754-8ccd-12b603324b89"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["higher temperature", "Subsubsection",
 CellChangeTimes->{{3.993728944119402*^9, 
  3.993728947603099*^9}},ExpressionUUID->"9fa412e9-93f1-499e-a404-\
343fba7e18b3"],

Cell["But, at higher temperatures \[Tau]=3", "Text",
 CellChangeTimes->{{3.993728231823062*^9, 
  3.993728245909246*^9}},ExpressionUUID->"49167473-dd61-48a6-9ccb-\
b805d2df7961"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"configuration", " ", "=", 
   RowBox[{"randomConfiguration", "[", 
    RowBox[{
     RowBox[{"1", "/", "2"}], ",", 
     RowBox[{"{", 
      RowBox[{"30", ",", "30"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"configuration", ",", " ", "statistics"}], "}"}], " ", "=", 
    RowBox[{"latticeGasMetropolisSweep", "[", 
     RowBox[{"configuration", ",", 
      RowBox[{"10", "^", "7"}], ",", "\[IndentingNewLine]", 
      RowBox[{"\"\<energyNearest\>\"", "\[Rule]", "1"}], ",", 
      RowBox[{"\"\<energyNextNearest\>\"", "\[Rule]", "0"}], ",", 
      RowBox[{"\"\<inverseTemperature\>\"", "\[Rule]", 
       RowBox[{"1", "/", "4"}]}], ",", 
      RowBox[{"\"\<exchangeProbability\>\"", "\[Rule]", "0"}], ",", 
      RowBox[{"\"\<occupiedSwitchFrequency\>\"", "\[Rule]", "1"}], ",", 
      RowBox[{"\"\<muBlue\>\"", "\[Rule]", "100"}], ",", 
      RowBox[{"\"\<muOrange\>\"", "\[Rule]", "100"}]}], "\[IndentingNewLine]",
      "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.993716706094471*^9, 3.9937167439947147`*^9}, {
  3.993717032629643*^9, 3.9937170358538103`*^9}, {3.993726852002329*^9, 
  3.993726932614458*^9}, {3.9937269879970837`*^9, 3.993727005530546*^9}, {
  3.9937276967424517`*^9, 3.9937277020226793`*^9}, {3.993727744149466*^9, 
  3.993727748859116*^9}, {3.993727795789817*^9, 3.9937280394364843`*^9}, {
  3.993728254420917*^9, 3.993728303971107*^9}, {3.993728436393628*^9, 
  3.9937284379510937`*^9}},
 CellLabel->
  "In[276]:=",ExpressionUUID->"8110b094-646d-4789-b50d-9dd24ddb0eec"],

