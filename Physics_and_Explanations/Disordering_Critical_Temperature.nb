Cell[CellGroupData[{

Cell["Simulating the order-disorder transition temperature.", "Chapter",
 CellChangeTimes->{{3.993724545867556*^9, 
  3.993724564516202*^9}},ExpressionUUID->"a0eb5a91-41ce-4c26-840f-\
dc17524ddaf8"],

Cell["We start from a random configuration:", "Text",
 CellChangeTimes->{{3.993726078124283*^9, 
  3.993726088127614*^9}},ExpressionUUID->"f2e6dae5-9c0a-4ad9-bb69-\
4131fcfdf503"],

Cell[BoxData[
 RowBox[{
  RowBox[{"randomConfiguration", "[", 
   RowBox[{"fractionOrange_", ",", 
    RowBox[{"{", 
     RowBox[{"width_", ",", "height_"}], "}"}]}], "]"}], ":=", " ", 
  "\[IndentingNewLine]", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"number", " ", "=", " ", 
       RowBox[{"width", " ", "height"}]}], ",", 
      RowBox[{"orange", " ", "=", " ", 
       RowBox[{"Round", "[", 
        RowBox[{"fractionOrange", " ", "width", " ", "height"}], "]"}]}]}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"ArrayPad", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ArrayReshape", "[", " ", 
       RowBox[{
        RowBox[{"RandomSample", "[", 
         RowBox[{
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"ConstantArray", "[", 
