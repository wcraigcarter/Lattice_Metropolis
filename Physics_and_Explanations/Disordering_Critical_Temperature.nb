Cell[BoxData[
 RowBox[{
  RowBox[{"randomConfiguration", "[", 
   RowBox[{"fractionOrange_", ",", 
    RowBox[{"{", 
     RowBox[{"width_", ",", "height_"}], "}"}]}], "]"}], ":=", " ", 
  "\[IndentingNewLine]", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"number", " ", "=", " ", 
       RowBox[{"width", " ", "height"}]}], ",", 
      RowBox[{"orange", " ", "=", " ", 
       RowBox[{"Round", "[", 
        RowBox[{"fractionOrange", " ", "width", " ", "height"}], "]"}]}]}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"ArrayPad", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ArrayReshape", "[", " ", 
       RowBox[{
        RowBox[{"RandomSample", "[", 
         RowBox[{
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"ConstantArray", "[", 
             RowBox[{"1", ",", "orange"}], "]"}], ",", 
            RowBox[{"ConstantArray", "[", 
             RowBox[{
              RowBox[{"-", "1"}], ",", 
              RowBox[{"number", " ", "-", " ", "orange"}]}], "]"}]}], "]"}], ",", 
          RowBox[{"height", " ", "width"}]}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"width", ",", "height"}], "}"}]}], "\[IndentingNewLine]", 
       "]"}], ",", "\[IndentingNewLine]", "1"}], "\[IndentingNewLine]", 
     "]"}]}], "\[IndentingNewLine]", "]"}]}]], "Code",
 CellChangeTimes->{
  3.9937276688204117`*^9},ExpressionUUID->"44da6d28-5290-41da-9600-\
fae25cb8de6c"],

Cell[CellGroupData[{

Cell["Order/Disorder Transition Temperature:\[LineSeparator]Lattice Gas", \
"Title",
 CellChangeTimes->{{3.993723121087268*^9, 
  3.9937231590174522`*^9}},ExpressionUUID->"4ab26fea-59de-4222-8bcf-\
6fd502d175e6"],

Cell[TextData[{
 "The",
 ButtonBox[" Ising model on a square lattice",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Ising_model"], None},
  ButtonNote->"https://en.wikipedia.org/wiki/Ising_model"],
 " is a special case of our Lattice Gas. \n\nFor the case where there are \
only first neighbor interactions, there is an exact solution (",
 ButtonBox["Onsager\[CloseCurlyQuote]s  Exact Solution",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Ising_model#Onsager's_exact_solution"],
     None},
  ButtonNote->
   "https://en.wikipedia.org/wiki/Ising_model#Onsager's_exact_solution"],
 ") for the transition from a checkerboard  to a disordered phase.\n\nThe \
critical temperate is given by: "
}], "Text",
 CellChangeTimes->{{3.993723210145829*^9, 3.993723266671281*^9}, {
  3.993723312871584*^9, 
  3.993723451799554*^9}},ExpressionUUID->"1b7034b5-3ec0-4b2c-8316-\
b7e360e5d927"],

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SuperscriptBox["sinh", "2"], 
        RowBox[{"(", 
          FractionBox[
           RowBox[{"2", 
             SubscriptBox[
              StyleBox["E", "TI"], "NN"]}], 
           RowBox[{
             SubscriptBox[
              StyleBox["k", "TI"], 
              StyleBox["b", "TI"]], 
             StyleBox["T", "TI"]}]], ")"}], "\[LongEqual]", "1"}], 
      TraditionalForm], "errors" -> {}, "input" -> 
    "\\sinh^2(\\frac{2E_{\\mbox{NN}}}{k_b T})=1", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], 
  TraditionalForm]],ExpressionUUID->"028277e7-f4eb-4c87-a3bd-60b94a1a0f52"]], \
"Text",
 CellChangeTimes->{
  3.993723457153922*^9},ExpressionUUID->"55a7b1d7-3da9-4c9d-b830-\
b9026d5a8591"],

Cell["Which has a solution:", "Text",
 CellChangeTimes->{{3.993723586194427*^9, 
  3.993723595959338*^9}},ExpressionUUID->"5ff4e201-1d34-44f1-852a-\
1b037ca76aa5"],

