Cell[CellGroupData[{

Cell["Samples as a function of temperature:", "Subsection",
 CellChangeTimes->{{3.993729738980852*^9, 
  3.993729753588312*^9}},ExpressionUUID->"4869ff13-6582-45b8-9994-\
dc1e1503a180"],

Cell[CellGroupData[{

Cell["Random Starting points", "Subsubsection",
 CellChangeTimes->{{3.9937299702409687`*^9, 
  3.993729975951455*^9}},ExpressionUUID->"84204bb7-73c1-4476-97a4-\
87b1119dbc19"],

Cell["\<\
We start with a evenly populated random configuration and anneal it at  a set \
of temperatures, and then take a thousand samples (each separated by 1000 \
Metropolis steps).
And then collect the average values\
\>", "Text",
 CellChangeTimes->{{3.99372979012241*^9, 3.993729870484223*^9}, {
  3.993729940166551*^9, 3.993729941234457*^9}, {3.9937300919354677`*^9, 
  3.993730189631802*^9}},ExpressionUUID->"b0e7d6a0-c957-4476-b219-\
58f76702410f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"width", " ", "=", " ", 
     RowBox[{"height", " ", "=", " ", "100"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"orderParameterTemperature", " ", "=", "\[IndentingNewLine]", 
      RowBox[{"Table", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"configuration", " ", "=", 
          RowBox[{"randomConfiguration", "[", 
           RowBox[{
            RowBox[{"1", "/", "2"}], ",", 
            RowBox[{"{", 
             RowBox[{"width", ",", "height"}], "}"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"configuration", ",", " ", "statistics"}], "}"}], " ", "=", 
          RowBox[{"latticeGasMetropolisSweep", "[", 
           RowBox[{"configuration", ",", 
            RowBox[{"10", "^", "7"}], ",", "\[IndentingNewLine]", 
            RowBox[{"\"\<energyNearest\>\"", "\[Rule]", "1"}], ",", 
            RowBox[{"\"\<energyNextNearest\>\"", "\[Rule]", "0"}], ",", 
            RowBox[{"\"\<muBlue\>\"", "\[Rule]", "100"}], ",", 
            RowBox[{"\"\<muOrange\>\"", "\[Rule]", "100"}], ",", 
            RowBox[{"\"\<inverseTemperature\>\"", "\[Rule]", 
             FractionBox["1", "temperature"]}], ",", 
            RowBox[{"\"\<exchangeProbability\>\"", "\[Rule]", "0"}], ",", 
            RowBox[{"\"\<occupiedSwitchFrequency\>\"", "\[Rule]", "1"}]}], 
           "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"checkerboardSamples", "=", "\[IndentingNewLine]", 
          RowBox[{"Table", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"configuration", ",", " ", "statistics"}], "}"}], " ", 
              "=", 
              RowBox[{"latticeGasMetropolisSweep", "[", 
               RowBox[{"configuration", ",", 
                RowBox[{"10", "^", "3"}], ",", "\[IndentingNewLine]", 
                InterpretationBox[
                 DynamicModuleBox[{Typeset`open = False}, 
                  TemplateBox[{"Expression", "SequenceIcon", 
                    GridBox[{{
                    RowBox[{
                    TagBox["\"Head: \"", "IconizedLabel"], 
                    "\[InvisibleSpace]", 
                    TagBox["Sequence", "IconizedItem"]}]}, {
                    RowBox[{
                    TagBox["\"Length: \"", "IconizedLabel"], 
                    "\[InvisibleSpace]", 
                    TagBox["7", "IconizedItem"]}]}, {
                    RowBox[{
                    TagBox["\"Byte count: \"", "IconizedLabel"], 
                    "\[InvisibleSpace]", 
                    TagBox["1032", "IconizedItem"]}]}}, 
                    GridBoxAlignment -> {"Columns" -> {{Left}}}, 
                    DefaultBaseStyle -> "Column", 
                    GridBoxItemSize -> {
                    "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
                    Dynamic[Typeset`open]},
                   "IconizedObject"]],
                 Sequence[
                 "energyNearest" -> 1, "energyNextNearest" -> 0, "muBlue" -> 
                  100, "muOrange" -> 100, "inverseTemperature" -> 
                  1/$CellContext`temperature, "exchangeProbability" -> 0, 
                  "occupiedSwitchFrequency" -> 1],
                 SelectWithContents->True,
                 Selectable->False]}], "\[IndentingNewLine]", "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"orderParameters", "=", 
              RowBox[{"latticeGasOrderParameterMaps", "[", 
               RowBox[{"configuration", ",", "8"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"Total", "[", 
              RowBox[{"Abs", "@", 
               RowBox[{"Flatten", "@", 
                RowBox[{
                "orderParameters", "[", "\"\<checkerboard\>\"", "]"}]}]}], 
              "]"}]}], ",", "\[IndentingNewLine]", "1000"}], 
           "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"temperature", ",", 
           FractionBox[
            RowBox[{"Mean", "[", "checkerboardSamples", "]"}], 
            RowBox[{"width", " ", "height"}]]}], "}"}]}], 
        "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"temperature", ",", "3", ",", ".1", ",", 
          RowBox[{"-", ".1"}]}], "}"}]}], "\[IndentingNewLine]", "]"}]}], 
     "\[IndentingNewLine]", ",", "\[IndentingNewLine]", "temperature"}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9937188909543533`*^9, 3.9937190951550207`*^9}, {
   3.9937191370673857`*^9, 3.993719194571391*^9}, {3.993719491258919*^9, 
   3.99371951216042*^9}, {3.993719600366301*^9, 3.9937196080761757`*^9}, {
   3.993719714095151*^9, 3.993719731623805*^9}, {3.993719765486167*^9, 
