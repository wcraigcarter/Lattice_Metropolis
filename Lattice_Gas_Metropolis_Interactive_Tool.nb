Cell[BoxData[
 RowBox[{
  RowBox[{"toolTipText", "=", " ", 
   RowBox[{"<|", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\"\<Nearest Neighbor\>\"", "->", 
      " ", "\"\<Energy is this coefficient \[Cross] (\[PlusMinus]1,\
\[PlusMinus]1). If negative, the system favors like-pairs as nearest \
neighbors \>\""}], ",", "\[IndentingNewLine]", 
     RowBox[{"\"\<Next Nearest Neighbor\>\"", 
      "->", "\"\<Energy is this coefficient \[Cross] (\[PlusMinus]1,\
\[PlusMinus]1). If negative, the system favors like-pairs as next nearest \
neighbors \>\""}], ",", "\[IndentingNewLine]", 
     RowBox[{"\"\<Speed\>\"", "->", 
      " ", "\"\<This is how many attempted switches are made before the \
graphic is redrawn\>\""}], ",", "\[IndentingNewLine]", 
     RowBox[{"\"\<\[Mu]Blue\>\"", 
      "->", "\"\<The chemical potential for replacing a vacancy with a blue \
atom. The is can be thought of as the vapor pressure of blue\>\""}]}], 
    "\[IndentingNewLine]", "|>"}]}], ";"}]], "Input",
 InitializationGroup->True,
